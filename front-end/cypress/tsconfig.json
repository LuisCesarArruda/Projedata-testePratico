{
    "compilerOptions": {
        "target": "ES2015",
        "lib": [
            "ES2015",
            "dom"
        ],
        "types": [
            "cypress",
            "node"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}